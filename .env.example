# ── Google OAuth ──────────────────────────────────────────────────────────────
# Register an OAuth 2.0 client and add https://<BASE_URL>/auth/callback as a redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Public URL ────────────────────────────────────────────────────────────────
# Used for OAuth callback and email links. If you serve under a sub-path,
# include the full prefix (e.g. https://example.com/charliework).
BASE_URL=https://charliework.example.com

# If you serve under a sub-path, set COOKIE_PATH to the same prefix.
# COOKIE_PATH=/charliework

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-32-bytes-hex

# ── Users ─────────────────────────────────────────────────────────────────────
# Either set USERS_JSON for full control:
#   USERS_JSON='{"alice":{"label":"Alice","emails":["alice@example.com"]},"bob":{"label":"Bob","emails":["bob@example.com"]}}'
# …or use the simpler two-user form (handles "user_a" and "user_b" internally):
USER_A_LABEL=User A
USER_A_EMAILS=user-a@example.com
USER_B_LABEL=User B
USER_B_EMAILS=user-b@example.com

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=America/Chicago

# ── Optional: daily ntfy task digest ──────────────────────────────────────────
# Leave NTFY_URL blank to disable. Cron expression is in server TZ.
NTFY_URL=
NTFY_TOPIC=charliework
NTFY_TOKEN=
DIGEST_CRON=0 7 * * *

# ── Optional: email digest of open "Ask Supervisor" questions ───────────────────────
QUESTION_DIGEST_ENABLED=false
QUESTION_DIGEST_CRON=0 8 * * 1-5
QUESTION_DIGEST_FROM="Charliework <charliework@example.com>"
QUESTION_DIGEST_TO=you@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_REQUIRE_TLS=true
# Optional auth (omit if your relay is IP-allowlisted)
# SMTP_USER=
# SMTP_PASS=

# ── Optional: seed date shortcuts on first run ────────────────────────────────
# JSON array of { label, date(YYYY-MM-DD) } objects. Inserted only when the
# shortcuts table is empty. You can also add/remove them in the in-app settings.
# DATE_SHORTCUTS_SEED='[{"label":"First day of school","date":"2026-08-14"},{"label":"End of 1st Quarter","date":"2026-10-15"}]'
